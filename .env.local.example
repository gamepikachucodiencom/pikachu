# ============================================
# Chinese Chess - Environment Variables
# ============================================
# Copy this file to .env.local and fill in your actual values
# Never commit .env.local to version control!

# ============================================
# SUPABASE CONFIGURATION (Required)
# ============================================
# Get these values from: Supabase Dashboard → Settings → API
# Project URL: https://app.supabase.com/project/_/settings/api

# Your Supabase project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Your Supabase anon/public key (safe to expose in client-side code)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ============================================
# DATABASE MIGRATIONS (Optional - for running migrations)
# ============================================
# Only needed if you want to run database migrations from your local machine
# Get this from: Supabase Dashboard → Settings → Database → Connection string
# Use the "URI" format (Direct connection, not Session mode)

# PostgreSQL connection string for migrations
# Format: postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:your-password@db.your-project-ref.supabase.co:5432/postgres

# Alternative names for database URL (migration script will try these if DATABASE_URL is not set)
# SUPABASE_DB_URL=postgresql://postgres:your-password@db.your-project-ref.supabase.co:5432/postgres
# POSTGRES_URL=postgresql://postgres:your-password@db.your-project-ref.supabase.co:5432/postgres

# Service role key (bypasses RLS - use only for migrations, never in client code)
# Get this from: Supabase Dashboard → Settings → API → service_role key
# WARNING: Keep this secret! Never expose in client-side code.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ============================================
# ADMIN PANEL CONFIGURATION (Optional)
# ============================================
# These settings control access to the admin panel at /admin

# Comma-separated list of IP addresses allowed to access admin panel
# Only applies to non-admin users (admin users can access from any IP)
# In development, all IPs are allowed regardless of this setting
# Default: 127.0.0.1,::1 (localhost)
ADMIN_ALLOWED_IPS=127.0.0.1,::1

# Comma-separated list of admin email addresses
# Users with these emails will automatically have admin access
# Alternative: Set role: 'admin' or isAdmin: true in Supabase user metadata
ADMIN_EMAILS=admin@example.com

# ============================================
# SEO & SITE CONFIGURATION (Optional)
# ============================================
# Used for generating metadata, sitemaps, and Open Graph tags

# Your site's public URL (used for SEO metadata)
# Default: https://yourdomain.com
# Example: https://chinese-chess.vercel.app
NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# ============================================
# NOTES
# ============================================
# - All NEXT_PUBLIC_* variables are exposed to the browser (client-side)
# - Never commit .env.local to version control
# - For production, set these in your hosting platform's environment variables
# - See README.md for detailed setup instructions
# - See MIGRATION_GUIDE.md for database migration instructions

